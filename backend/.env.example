# Server Configuration
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# Database
MONGODB_URI=mongodb://mongo:27017/control-panel

# JWT Configuration
# IMPORTANT: Change this in production! Must be at least 32 characters
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-characters-long
JWT_EXPIRES_IN=24h

# Admin User (created automatically on first run)
ADMIN_EMAIL=admin@example.com
# IMPORTANT: Change this password in production!
ADMIN_PASSWORD=change-this-secure-password

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

# ===================================
# OPTIONAL INTEGRATIONS
# Configure these to enable integrations
# ===================================

# Email/SMTP (Gmail example)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=Control Panel <noreply@example.com>

# Notion Integration
# Get token from: https://www.notion.so/my-integrations
# NOTION_TOKEN=secret_abc123...
# NOTION_DATABASE_ID=abc123def456...

# Portainer Integration
# PORTAINER_URL=https://portainer.example.com
# PORTAINER_TOKEN=ptr_abc123...
# PORTAINER_ENDPOINT_ID=1
