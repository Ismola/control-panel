# Server Configuration
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URI=mongodb://mongo:27017/control-panel
# For production with external MongoDB:
# MONGODB_URI=mongodb://username:password@your-mongo-host:27017/control-panel?authSource=admin

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=24h

# Initial Admin User (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-secure-password

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Log Level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
