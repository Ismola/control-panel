{
    "name": "control-panel-backend",
    "version": "1.0.0",
    "description": "Service monitoring control panel backend API",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix"
    },
    "keywords": [
        "monitoring",
        "notifications",
        "portainer",
        "healthcheck"
    ],
    "author": "Ismola",
    "license": "MIT",
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "@fastify/jwt": "^9.0.1",
        "@fastify/swagger": "^9.3.0",
        "@fastify/swagger-ui": "^5.0.1",
        "@notionhq/client": "^2.2.15",
        "@sinclair/typebox": "^0.34.11",
        "axios": "^1.7.9",
        "bcrypt": "^5.1.1",
        "dotenv": "^16.4.7",
        "fastify": "^5.2.0",
        "mongoose": "^8.9.3",
        "node-schedule": "^2.1.1",
        "nodemailer": "^6.9.16",
        "pino": "^9.5.0",
        "pino-pretty": "^13.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/node": "^22.10.2",
        "@types/node-schedule": "^2.1.7",
        "@types/nodemailer": "^6.4.17",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.18.2",
        "@typescript-eslint/parser": "^8.18.2",
        "@vitest/coverage-v8": "^2.1.8",
        "eslint": "^9.17.0",
        "supertest": "^7.0.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}